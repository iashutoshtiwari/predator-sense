post_install() {
  systemctl daemon-reload >/dev/null 2>&1 || true
  systemctl enable --now predator-sense.service >/dev/null 2>&1 || true
}

post_upgrade() {
  post_install
}

pre_remove() {
  systemctl disable --now predator-sense.service >/dev/null 2>&1 || true
}

post_remove() {
  systemctl daemon-reload >/dev/null 2>&1 || true
}
